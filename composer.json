{
	"name": "model/skeleton",
	"description": "Skeleton for a ModEl Framework 4 application (composer create-project template)",
	"type": "project",
	"license": "proprietary",
	"authors": [
		{
			"name": "Domenico Giambra",
			"email": "zorinik@gmail.com"
		}
	],
	"require": {
		"php": "^8.1",
		"ext-curl": "*",
		"ext-json": "*",
		"model/assets": "^0.4",
		"model/core": "^0.4",
		"model/router": "^0.2",
		"model/settings": "^0.2"
	},
	"autoload": {
		"psr-4": {
			"Model\\Skeleton\\": "src/"
		}
	},
	"scripts": {
		"post-create-project-cmd": [
			"Model\\Skeleton\\Installer::run"
		]
	},
	"config": {
		"sort-packages": true
	}
}
